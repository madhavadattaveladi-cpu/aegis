# ============================================================
# AEGIS configuration. Copy this file to ".env" and edit.
#   On Windows PowerShell:  Copy-Item .env.example .env
# ============================================================

# Which LLM backend to use: "ollama" (free/local) or "claude" (cloud API).
AEGIS_LLM_BACKEND=ollama

# --- Ollama settings (used when backend=ollama) ---
# Install Ollama from https://ollama.com, then run:  ollama pull llama3.1
AEGIS_OLLAMA_MODEL=llama3.1
AEGIS_OLLAMA_HOST=http://localhost:11434

# --- Claude settings (used when backend=claude) ---
# Get a key at https://console.anthropic.com  (keep it secret, never commit .env)
AEGIS_ANTHROPIC_API_KEY=
AEGIS_CLAUDE_MODEL=claude-sonnet-4-6

# --- Scraping behaviour ---
AEGIS_USER_AGENT=AegisBot/0.1 (+https://github.com/yourname/aegis)
AEGIS_REQUEST_DELAY_SECONDS=1.0
AEGIS_MAX_CONCURRENCY=4
AEGIS_RESPECT_ROBOTS=true

# --- Storage ---
AEGIS_OUTPUT_DIR=data/output
